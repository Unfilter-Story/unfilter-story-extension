# Environment Variables for Unfilter Story API Backend

# Database Configuration 
# This matches the docker-compose.yml credentials
DATABASE_URL="postgresql://unfilter:password@localhost:5432/unfilter_story?schema=public"

# Application Settings
PORT=3000
NODE_ENV="development"

# Security
# Run `openssl rand -base64 32` to generate a strong secret
JWT_SECRET="generate-a-strong-jwt-secret-for-production"

# External API Keys (Future)
# CLOUDFLARE_R2_ACCESS_KEY=
# CLOUDFLARE_R2_SECRET_KEY=
# CLOUDFLARE_R2_BUCKET=
